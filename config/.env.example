# OpenACM Environment Variables
# Copy this file to .env and fill in your values

# LLM API Keys (only needed for cloud providers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENCODE_GO_API_KEY=

# Channel Tokens (leave empty until configured)
DISCORD_TOKEN=
TELEGRAM_TOKEN=

# Web Dashboard
DASHBOARD_TOKEN=

# Ollama (if running on a different host)
# OLLAMA_BASE_URL=http://localhost:11434
